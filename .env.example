# Фронтенд (Vite) — скопируйте в .env.local для локальной разработки
# На сервере эти переменные задаются перед npm run build

# Канонический адрес сайта (без слэша в конце)
VITE_SITE_URL=https://advokat-tuapse.ru

# Коды подтверждения из Google Search Console и Яндекс.Вебмастер
# Получите их после регистрации сайта (см. инструкцию в ответе ассистента)
VITE_GOOGLE_SITE_VERIFICATION=
VITE_YANDEX_VERIFICATION=
